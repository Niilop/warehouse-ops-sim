    order_id: str
    items_picked: int
    distance_traveled: int
    ticks_taken: int
    completed_at_tick: int
    wait_ticks: int = 0
    item_ids: list[str] = field(default_factory=list)


@dataclass
class SimMetrics:
    total_orders: int
    total_items: int
    total_distance: int
    total_ticks: int
    lines_per_hour: float   # items / total_ticks * 3600 (1 tick ≈ 1 second scale)
    idle_ticks: int
    wait_ticks_total: int
    stockout_count: int


class Simulation:

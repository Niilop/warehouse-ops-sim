from warehouse.task import Task, TaskType


def _poisson_draw(lam: float, rng: random.Random) -> int:
    """Exact Poisson draw via Knuth's algorithm. Returns 0 for lam <= 0."""
    if lam <= 0:
        return 0
    L = math.exp(-lam)
    k, p = 0, 1.0
    while p > L:
        k += 1
        p *= rng.random()
    return k - 1


@dataclass
class RestockJob:
    item_id: str
    item: Item
    ready_at_tick: int


@dataclass
